<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nafees Shaikh — Data Scientist &amp; Analyst</title>
<meta name="description" content="Nafees Shaikh — Data Science graduate specializing in Python, SQL, Power BI, Tableau and machine learning. Turning data into decisions.">

<style>
/* ============================================================
   TOKENS
   ============================================================ */
:root{
  --ink:#0B0E14;
  --ink-surface:#12161F;
  --ink-surface-2:#181D28;
  --ink-line:rgba(232,234,237,0.09);
  --ink-line-strong:rgba(232,234,237,0.16);
  --text:#E8EAED;
  --text-dim:#9BA3AF;
  --text-faint:#5C6472;

  --accent:#F2A93B;      /* signal amber */
  --accent-ink:#0B0E14;
  --accent-2:#4FB3A5;    /* data teal */
  --danger:#E2685A;

  --paper:#EEF0F3;
  --paper-surface:#FFFFFF;
  --paper-surface-2:#F5F6F8;
  --paper-line:rgba(11,14,20,0.10);
  --paper-line-strong:rgba(11,14,20,0.18);
  --paper-text:#12151C;
  --paper-text-dim:#565D6B;
  --paper-text-faint:#8A909C;

  --bg:var(--ink);
  --surface:var(--ink-surface);
  --surface-2:var(--ink-surface-2);
  --line:var(--ink-line);
  --line-strong:var(--ink-line-strong);
  --fg:var(--text);
  --fg-dim:var(--text-dim);
  --fg-faint:var(--text-faint);

  --font-display:'Space Grotesk', sans-serif;
  --font-body:'IBM Plex Sans', sans-serif;
  --font-mono:'IBM Plex Mono', monospace;

  --container:1180px;
  --radius:14px;
  --ease:cubic-bezier(.22,1,.36,1);
}

html[data-theme="light"]{
  --bg:var(--paper);
  --surface:var(--paper-surface);
  --surface-2:var(--paper-surface-2);
  --line:var(--paper-line);
  --line-strong:var(--paper-line-strong);
  --fg:var(--paper-text);
  --fg-dim:var(--paper-text-dim);
  --fg-faint:var(--paper-text-faint);
  --accent-ink:#0B0E14;
}

*,*::before,*::after{box-sizing:border-box;}
html{scroll-behavior:smooth;}
@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto;}
  *,*::before,*::after{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important; scroll-behavior:auto !important;}
}

body{
  margin:0;
  background:var(--bg);
  color:var(--fg);
  font-family:var(--font-body);
  font-size:16px;
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  transition:background .4s var(--ease), color .4s var(--ease);
  overflow-x:hidden;
}

img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
ul{margin:0;padding:0;list-style:none;}
h1,h2,h3,h4{margin:0;font-family:var(--font-display);font-weight:600;letter-spacing:-0.01em;}
p{margin:0;}
button{font-family:inherit;cursor:pointer;}

.container{max-width:var(--container);margin:0 auto;padding:0 32px;}
.eyebrow{
  font-family:var(--font-mono);
  font-size:12.5px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--accent);
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:18px;
}
.eyebrow::before{
  content:"";
  width:20px;height:1px;
  background:var(--accent);
  display:inline-block;
}

.section{padding:120px 0;position:relative;}
.section-head{max-width:640px;margin-bottom:64px;}
.section-title{font-size:clamp(28px,4vw,42px);line-height:1.15;}
.section-desc{margin-top:16px;color:var(--fg-dim);font-size:16.5px;max-width:560px;}

/* reveal on scroll */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .8s var(--ease), transform .8s var(--ease);}
.reveal.in{opacity:1;transform:translateY(0);}
.reveal-stagger > *{opacity:0;transform:translateY(24px);transition:opacity .7s var(--ease), transform .7s var(--ease);}
.reveal-stagger.in > *{opacity:1;transform:translateY(0);}
.reveal-stagger.in > *:nth-child(1){transition-delay:.05s;}
.reveal-stagger.in > *:nth-child(2){transition-delay:.12s;}
.reveal-stagger.in > *:nth-child(3){transition-delay:.19s;}
.reveal-stagger.in > *:nth-child(4){transition-delay:.26s;}
.reveal-stagger.in > *:nth-child(5){transition-delay:.33s;}
.reveal-stagger.in > *:nth-child(6){transition-delay:.40s;}
.reveal-stagger.in > *:nth-child(7){transition-delay:.47s;}

/* ============================================================
   NAV
   ============================================================ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  border-bottom:1px solid transparent;
  background:transparent;
  transition:background .4s var(--ease), border-color .4s var(--ease), backdrop-filter .4s var(--ease);
}
.nav.scrolled{
  background:color-mix(in srgb, var(--bg) 82%, transparent);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--line);
}
.nav-inner{
  max-width:var(--container);margin:0 auto;padding:20px 32px;
  display:flex;align-items:center;justify-content:space-between;
}
.brand{
  font-family:var(--font-mono);font-size:15px;letter-spacing:.02em;
  display:flex;align-items:center;gap:10px;
}
.brand .dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);}
.nav-links{display:flex;gap:36px;}
.nav-links a{
  font-size:14px;color:var(--fg-dim);position:relative;padding:4px 0;
  transition:color .25s;
}
.nav-links a::after{
  content:"";position:absolute;left:0;bottom:0;height:1px;width:0;
  background:var(--accent);transition:width .3s var(--ease);
}
.nav-links a:hover{color:var(--fg);}
.nav-links a:hover::after{width:100%;}
.nav-right{display:flex;align-items:center;gap:18px;}

.theme-toggle{
  width:46px;height:26px;border-radius:20px;border:1px solid var(--line-strong);
  background:var(--surface-2);position:relative;padding:0;flex-shrink:0;
}
.theme-toggle .knob{
  position:absolute;top:2px;left:2px;width:20px;height:20px;border-radius:50%;
  background:var(--accent);transition:transform .35s var(--ease);
  display:flex;align-items:center;justify-content:center;
}
html[data-theme="light"] .theme-toggle .knob{transform:translateX(20px);}
.theme-toggle svg{width:12px;height:12px;}

.nav-cta{
  font-size:13.5px;font-family:var(--font-mono);
  border:1px solid var(--line-strong);border-radius:8px;padding:9px 16px;
  color:var(--fg);white-space:nowrap;transition:border-color .25s, background .25s;
}
.nav-cta:hover{border-color:var(--accent);background:color-mix(in srgb, var(--accent) 10%, transparent);}

.menu-btn{display:none;background:none;border:none;color:var(--fg);}

/* ============================================================
   HERO
   ============================================================ */
.hero{
  min-height:100vh;
  display:flex;align-items:center;
  position:relative;
  padding-top:100px;
  overflow:hidden;
}
#hero-canvas{
  position:absolute;inset:0;width:100%;height:100%;
  opacity:.55;
}
.hero-inner{
  position:relative;z-index:2;
  max-width:var(--container);margin:0 auto;padding:0 32px;
  width:100%;
}
.hero-layout{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;
}
.hero-content{
  display:flex;
  flex-direction:column;
}
.hero-kicker{
  font-family:var(--font-mono);font-size:13px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--accent-2);margin-bottom:22px;display:flex;align-items:center;gap:10px;
}
.status-dot{width:7px;height:7px;border-radius:50%;background:#3ECF8E;position:relative;}
.status-dot::after{
  content:"";position:absolute;inset:-4px;border-radius:50%;border:1px solid #3ECF8E;
  animation:pulse-ring 2.2s ease-out infinite;
}
@keyframes pulse-ring{0%{transform:scale(.6);opacity:.8;}100%{transform:scale(2.1);opacity:0;}}

.hero-title{
  font-size:clamp(40px,7.2vw,84px);
  line-height:1.02;
  letter-spacing:-0.02em;
  max-width:900px;
}
.hero-title .line{display:block;overflow:hidden;}
.hero-title .line span{display:inline-block;transform:translateY(110%);transition:transform .9s var(--ease);}
.hero-title .line:nth-child(1) span{transition-delay:.1s;}
.hero-title .line:nth-child(2) span{transition-delay:.22s;}
.loaded .hero-title .line span{transform:translateY(0);}
.hero-title .accent-text{color:var(--accent);font-style:italic;}

.hero-sub{
  margin-top:28px;max-width:540px;color:var(--fg-dim);font-size:17px;
  opacity:0;transform:translateY(14px);transition:opacity .8s var(--ease) .5s, transform .8s var(--ease) .5s;
}
.loaded .hero-sub{opacity:1;transform:translateY(0);}

.hero-actions{
  margin-top:40px;display:flex;gap:16px;flex-wrap:wrap;align-items:center;
  opacity:0;transform:translateY(14px);transition:opacity .8s var(--ease) .65s, transform .8s var(--ease) .65s;
}
.loaded .hero-actions{opacity:1;transform:translateY(0);}

.btn{
  font-family:var(--font-mono);font-size:14px;
  padding:14px 26px;border-radius:9px;
  display:inline-flex;align-items:center;gap:10px;
  transition:transform .3s var(--ease), box-shadow .3s var(--ease), background .3s var(--ease), border-color .3s;
  border:1px solid transparent;
}
.btn-primary{background:var(--accent);color:var(--accent-ink);font-weight:600;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px -8px color-mix(in srgb, var(--accent) 60%, transparent);}
.btn-ghost{border-color:var(--line-strong);color:var(--fg);}
.btn-ghost:hover{border-color:var(--accent);transform:translateY(-2px);}
.btn svg{width:16px;height:16px;}

.hero-stats{
  margin-top:80px;display:flex;gap:0;flex-wrap:wrap;
  border-top:1px solid var(--line);
  opacity:0;transition:opacity 1s var(--ease) .9s;
}
.loaded .hero-stats{opacity:1;}
.stat{
  padding:24px 36px 0 0;margin-right:36px;border-right:1px solid var(--line);
  flex:1 1 auto;min-width:140px;
}
.stat:last-child{border-right:none;}
.stat-num{
  font-family:var(--font-mono);font-size:34px;color:var(--fg);
  display:flex;align-items:baseline;gap:2px;
}
.stat-num .accent{color:var(--accent);}
.stat-label{margin-top:6px;font-size:13px;color:var(--fg-faint);}

.scroll-cue{
  position:absolute;bottom:38px;left:32px;
  display:flex;align-items:center;gap:12px;
  font-family:var(--font-mono);font-size:11.5px;color:var(--fg-faint);
  letter-spacing:.1em;text-transform:uppercase;
}
.scroll-cue .bar{width:1px;height:32px;background:var(--line-strong);position:relative;overflow:hidden;}
.scroll-cue .bar::after{
  content:"";position:absolute;top:-100%;left:0;width:100%;height:100%;background:var(--accent);
  animation:scrolldown 1.8s ease-in-out infinite;
}
@keyframes scrolldown{0%{top:-100%;}60%{top:100%;}100%{top:100%;}}

/* profile photo - large side image */
.profile-photo{
  width:100%;
  max-width:420px;
  aspect-ratio:1/1;
  border-radius:50%;
  border:3px solid var(--accent);
  padding:6px;
  position:relative;
  margin:0 auto;
  opacity:0;
  transform:scale(0.92);
  transition:opacity .8s var(--ease) .2s, transform .8s var(--ease) .2s;
}
.loaded .profile-photo{opacity:1;transform:scale(1);}
.profile-photo .photo-inner{
  width:100%;height:100%;border-radius:50%;overflow:hidden;
  background:var(--surface-2);display:flex;align-items:center;justify-content:center;
}
.profile-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.profile-photo img.broken{display:none;}
.profile-photo .fallback{
  display:none;flex-direction:column;align-items:center;justify-content:center;
  font-family:var(--font-mono);color:var(--fg-faint);text-align:center;gap:4px;
}
.profile-photo .fallback strong{font-size:28px;color:var(--fg-dim);font-family:var(--font-display);}
.profile-photo .fallback span{font-size:10px;letter-spacing:.03em;line-height:1.3;padding:0 10px;}
.profile-photo.no-photo .fallback{display:flex;}

/* profile ring animation */
.profile-photo::before{
  content:'';
  position:absolute;
  inset:-10px;
  border-radius:50%;
  border:2px solid rgba(0,212,176,0.12);
  animation:spin-slow 24s linear infinite;
}
.profile-photo::after{
  content:'';
  position:absolute;
  inset:-6px;
  border-radius:50%;
  border:2px solid transparent;
  border-top-color:var(--accent-2);
  border-right-color:var(--accent);
  animation:spin-slow 16s linear infinite reverse;
}
@keyframes spin-slow{
  to{transform:rotate(360deg);}
}

/* ============================================================
   ABOUT
   ============================================================ */
.about-grid{display:grid;grid-template-columns:1fr;gap:64px;align-items:start;}
.about-text{max-width:720px;}
.about-text p{color:var(--fg-dim);font-size:16.5px;margin-bottom:20px;}
.about-text p:last-child{margin-bottom:0;}
.about-text strong{color:var(--fg);font-weight:600;}
.avail-badge{
  display:inline-flex;align-items:center;gap:10px;margin-top:28px;
  font-family:var(--font-mono);font-size:13px;
  border:1px solid var(--line-strong);border-radius:99px;padding:8px 16px 8px 12px;
}
.info-card{
  background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
  padding:28px;
}
.info-row{
  display:flex;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--line);
  font-size:14.5px;
}
.info-row:last-child{border-bottom:none;padding-bottom:0;}
.info-row:first-child{padding-top:0;}
.info-row .k{color:var(--fg-faint);font-family:var(--font-mono);font-size:12.5px;text-transform:uppercase;letter-spacing:.06em;}
.info-row .v{color:var(--fg);text-align:right;font-weight:500;}

/* ============================================================
   SKILLS
   ============================================================ */
.skills-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:1px;
  background:var(--line);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;
}
.skill-card{background:var(--surface);padding:28px 22px;transition:background .3s;}
.skill-card:hover{background:var(--surface-2);}
.skill-card h4{
  font-size:14px;font-family:var(--font-mono);color:var(--accent-2);margin-bottom:16px;
  text-transform:uppercase;letter-spacing:.05em;display:flex;align-items:center;gap:9px;
}
.skill-card h4 svg{width:16px;height:16px;flex-shrink:0;}
.skill-card ul li{
  font-size:14.5px;color:var(--fg-dim);padding:7px 0;
  display:flex;align-items:center;gap:10px;
}
.skill-card ul li svg{width:15px;height:15px;flex-shrink:0;color:var(--fg-faint);transition:color .25s;}
.skill-card ul li:hover svg{color:var(--accent);}
.skill-card ul li:hover{color:var(--fg);}

/* ============================================================
   EXPERIENCE (timeline)
   ============================================================ */
.timeline{position:relative;padding-left:32px;}
.timeline::before{
  content:"";position:absolute;left:0;top:6px;bottom:6px;width:1px;background:var(--line-strong);
}
.tl-item{position:relative;padding-bottom:56px;}
.tl-item:last-child{padding-bottom:0;}
.tl-item::before{
  content:"";position:absolute;left:-37px;top:6px;width:11px;height:11px;border-radius:50%;
  background:var(--bg);border:2px solid var(--accent);
}
.tl-date{
  font-family:var(--font-mono);font-size:12.5px;color:var(--accent);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px;
  display:flex;align-items:center;gap:10px;
}
.tl-current{
  background:color-mix(in srgb, var(--accent) 16%, transparent);
  color:var(--accent);border:1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  padding:2px 9px;border-radius:99px;font-size:10.5px;letter-spacing:.05em;
}
.tl-role{font-size:20px;margin-bottom:2px;}
.tl-org{font-size:14.5px;color:var(--fg-dim);margin-bottom:16px;}
.tl-list{margin-top:14px;}
.tl-list li{
  font-size:15px;color:var(--fg-dim);padding:6px 0 6px 20px;position:relative;
}
.tl-list li::before{content:"—";position:absolute;left:0;color:var(--fg-faint);}

/* ============================================================
   PROJECTS
   ============================================================ */
.filter-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:44px;}
.filter-btn{
  font-family:var(--font-mono);font-size:13px;padding:9px 16px;border-radius:99px;
  border:1px solid var(--line-strong);color:var(--fg-dim);transition:all .25s var(--ease);background:transparent;
}
.filter-btn:hover{color:var(--fg);border-color:var(--fg-faint);}
.filter-btn.active{background:var(--accent);color:var(--accent-ink);border-color:var(--accent);font-weight:600;}

.projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;}
.project-card{
  background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
  padding:0 0 30px;position:relative;overflow:hidden;
  transition:transform .45s var(--ease), border-color .35s;
  transform-style:preserve-3d;
}
.project-card.hidden{display:none;}
.project-card:hover{border-color:var(--line-strong);}
.project-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:2px;z-index:2;
  background:linear-gradient(90deg, var(--accent), var(--accent-2));
  transform:scaleX(0);transform-origin:left;transition:transform .5s var(--ease);
}
.project-card:hover::before{transform:scaleX(1);}
.pc-media{
  width:100%;aspect-ratio:16/10;overflow:hidden;position:relative;
  background:var(--surface-2);border-bottom:1px solid var(--line);
}
.pc-media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s var(--ease);}
.project-card:hover .pc-media img{transform:scale(1.06);}
.pc-body{padding:26px 30px 0;}
.pc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:22px;}
.pc-cat{
  font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--accent-2);border:1px solid color-mix(in srgb, var(--accent-2) 40%, transparent);
  padding:5px 10px;border-radius:99px;
}
.pc-links{display:flex;gap:10px;}
.pc-links a{
  width:34px;height:34px;border-radius:8px;border:1px solid var(--line-strong);
  display:flex;align-items:center;justify-content:center;transition:all .25s;
}
.pc-links a:hover{background:var(--accent);border-color:var(--accent);color:var(--accent-ink);transform:translateY(-2px);}
.pc-links svg{width:15px;height:15px;}
.project-card h3{font-size:21px;margin-bottom:10px;}
.project-card p{color:var(--fg-dim);font-size:14.5px;line-height:1.65;}

/* ============================================================
   CERTIFICATIONS (card grid)
   ============================================================ */
.certs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
.cert-card{
  background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);
  overflow:hidden;transition:transform .4s var(--ease), border-color .35s;
  position:relative;
}
.cert-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:2px;z-index:2;
  background:linear-gradient(90deg, var(--accent), var(--accent-2));
  transform:scaleX(0);transform-origin:left;transition:transform .5s var(--ease);
}
.cert-card:hover{border-color:var(--line-strong);transform:translateY(-4px);}
.cert-card:hover::before{transform:scaleX(1);}
.cert-media{
  width:100%;aspect-ratio:4/3;overflow:hidden;position:relative;
  background:var(--surface-2);border-bottom:1px solid var(--line);
  display:flex;align-items:center;justify-content:center;
}
.cert-media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s var(--ease);}
.cert-media img.broken{display:none;}
.cert-media .cert-fallback{display:none;flex-direction:column;align-items:center;gap:8px;color:var(--fg-faint);}
.cert-media.no-img .cert-fallback{display:flex;}
.cert-media .cert-fallback svg{width:26px;height:26px;}
.cert-media .cert-fallback span{font-family:var(--font-mono);font-size:10px;letter-spacing:.05em;text-align:center;padding:0 14px;}
.cert-card:hover .cert-media img{transform:scale(1.06);}
.cert-badge{
  position:absolute;top:12px;left:12px;z-index:2;
  font-family:var(--font-mono);font-size:10.5px;letter-spacing:.05em;
  background:var(--accent);color:var(--accent-ink);padding:5px 10px;border-radius:99px;font-weight:600;
}
.cert-body{padding:20px 22px 22px;}
.cert-org{
  font-family:var(--font-mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--accent-2);margin-bottom:8px;
}
.cert-title{font-size:16.5px;line-height:1.35;margin-bottom:14px;min-height:44px;}
.cert-link{
  font-family:var(--font-mono);font-size:12.5px;color:var(--fg-dim);
  display:inline-flex;align-items:center;gap:6px;transition:color .25s;
}
.cert-card:hover .cert-link{color:var(--accent-2);}
.cert-link svg{width:12px;height:12px;}
